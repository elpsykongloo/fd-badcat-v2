# Existing repository locations
FDBC_REPO_ROOT=/root/autodl-tmp/fd-badcat
FDBC_SRC_DIR=/root/autodl-tmp/fd-badcat/src
FDBENCH_REPO_ROOT=/root/autodl-tmp/FDBench_v3
FDB_V3_DIR=/root/autodl-tmp/FDBench_v3/v3
FDB_V3_DATA_DIR=/root/autodl-tmp/FDBench_v3/v3/fdb_v3_data_released

# fd-badcat/Qwen3-Omni-compatible decision endpoint
FDBC_QWEN_URL=http://127.0.0.1:10004/v1/chat/completions
FDBC_QWEN_MODEL=Qwen3-Omni-30B-A3B-Instruct
FDBC_QWEN_TIMEOUT=600
FDBC_QWEN_MAX_TOKENS=768
FDBC_QWEN_TEMPERATURE=0
FDBC_QWEN_SEED=42
