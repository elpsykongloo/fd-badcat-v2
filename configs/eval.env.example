# Source this before running strict original evaluation scripts.
#
#   source configs/eval.env.example
#   export DEEPSEEK_API_KEY=sk-...

export OMP_NUM_THREADS=8
export MKL_NUM_THREADS=8

export HF_HOME=/root/autodl-tmp/fd-badcat/.cache/huggingface
export MODELSCOPE_CACHE=/root/autodl-tmp/fd-badcat/.cache/modelscope

export FDBC_FUNASR_MODEL=paraformer-zh
export FDBC_FUNASR_MODEL_REVISION=v2.0.4
export FDBC_FUNASR_VAD_MODEL=fsmn-vad
export FDBC_FUNASR_VAD_MODEL_REVISION=v2.0.4

export FDBC_PARAKEET_MODEL=nvidia/parakeet-tdt-0.6b-v2
export FDBC_PARAKEET_NEMO=/root/autodl-tmp/fd-badcat/model/parakeet-tdt-0.6b-v2/parakeet-tdt-0.6b-v2.nemo

export DEEPSEEK_BASE_URL=https://api.deepseek.com
export DEEPSEEK_MODEL=deepseek-chat
export DEEPSEEK_TIMEOUT=120
# export DEEPSEEK_API_KEY=sk-...
